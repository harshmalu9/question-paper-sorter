# ==================================================
# Python
# ==================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ==================================================
# Virtual Environment
# ==================================================
venv/
.env
.env.*

# ==================================================
# IDEs
# ==================================================
.vscode/
.idea/

# ==================================================
# OS Files
# ==================================================
.DS_Store
Thumbs.db

# ==================================================
# Logs
# ==================================================
logs/
*.log

# ==================================================
# Runtime Cache
# ==================================================
data/cache/*
!data/cache/.gitkeep

# ==================================================
# Temporary Images (PDF → images conversion)
# ==================================================
data/temp/*
!data/temp/.gitkeep

# ==================================================
# Generated Outputs (CLI runs)
# ==================================================
output/
output2/

# ==================================================
# Input PDFs (user-supplied, not committed)
# ==================================================
data/input/*
!data/input/.gitkeep

# ==================================================
# Backend Uploads & Job Results
# ==================================================
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/results/
!backend/uploads/results/.gitkeep
# ==================================================
# Testing
# ==================================================
.pytest_cache/
coverage/
htmlcov/

# ==================================================
# Jupyter
# ==================================================
.ipynb_checkpoints/

# ==================================================
# Editor Swap Files
# ==================================================
*.swp
*.swo
*~
